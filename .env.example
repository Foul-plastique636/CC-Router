# cc-router environment variables
# Copy this to .env and fill in your values (never commit .env)

# Port the proxy listens on (default: 3456)
PORT=3456

# Target URL — leave empty for standalone mode (direct to Anthropic)
# Set to http://localhost:4000 for full mode with LiteLLM
LITELLM_URL=

# Path to accounts.json (default: ~/.cc-router/accounts.json)
ACCOUNTS_PATH=

# Optional: master key for LiteLLM UI (full mode only)
LITELLM_MASTER_KEY=cc-router-dev
